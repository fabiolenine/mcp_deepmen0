# mem0-mcp-selfhosted environment variables
# Copy to .env and fill in values. Never commit .env with real secrets.

# --- LLM Provider ---
# MEM0_LLM_PROVIDER=anthropic          # anthropic | ollama
# MEM0_LLM_MODEL=claude-opus-4-6       # Model name (default depends on provider)
# MEM0_LLM_MAX_TOKENS=16384
# MEM0_LLM_URL=http://localhost:11434   # Ollama base URL (only for ollama provider)

# --- Anthropic Auth (pick one) ---
# MEM0_ANTHROPIC_TOKEN=               # OAuth/OAT token (highest priority)
# ANTHROPIC_API_KEY=                   # Standard API key (fallback)

# --- Embedder ---
# MEM0_EMBED_PROVIDER=ollama
# MEM0_EMBED_MODEL=bge-m3
# MEM0_EMBED_URL=http://localhost:11434
# MEM0_EMBED_DIMS=1024

# --- Vector Store (Qdrant) ---
# MEM0_QDRANT_URL=http://localhost:6333
# MEM0_COLLECTION=mem0_mcp_selfhosted
# MEM0_QDRANT_API_KEY=
# MEM0_QDRANT_ON_DISK=false

# --- Graph Store (Neo4j) ---
# MEM0_ENABLE_GRAPH=false
# MEM0_NEO4J_URL=bolt://127.0.0.1:7687
# MEM0_NEO4J_USER=neo4j
# MEM0_NEO4J_PASSWORD=mem0graph
# MEM0_NEO4J_DATABASE=
# MEM0_NEO4J_BASE_LABEL=
# MEM0_GRAPH_THRESHOLD=0.7

# --- Graph LLM ---
# MEM0_GRAPH_LLM_PROVIDER=anthropic    # anthropic | ollama | gemini | gemini_split
# MEM0_GRAPH_LLM_MODEL=                # Defaults to MEM0_LLM_MODEL
# MEM0_GRAPH_LLM_URL=                  # Defaults to MEM0_LLM_URL (ollama only)

# --- Gemini (for graph LLM) ---
# GOOGLE_API_KEY=

# --- Split-model Graph LLM (gemini_split) ---
# MEM0_GRAPH_CONTRADICTION_LLM_PROVIDER=anthropic
# MEM0_GRAPH_CONTRADICTION_LLM_MODEL=

# --- Server ---
# MEM0_HOST=0.0.0.0
# MEM0_PORT=8081
# MEM0_TRANSPORT=stdio                 # stdio | sse | streamable-http
# MEM0_LOG_LEVEL=INFO

# --- Memory Defaults ---
# MEM0_USER_ID=default
# MEM0_HISTORY_DB_PATH=

# --- Async ingest queue (v0.4) ---
# MEM0_ASYNC_INGEST=true               # false = synchronous add_memory (kill switch)
# MEM0_QUEUE_DB_PATH=                  # default: <history dir>/ingest_queue.db (~/.mem0/)
# MEM0_QUEUE_MAX_ATTEMPTS=4
# MEM0_QUEUE_BACKOFF_BASE=30           # seconds; exponential (30, 60, 120, ...)
# MEM0_QUEUE_POLL_INTERVAL=2
# MEM0_QUEUE_EST_ADD_S=40              # wait-estimate cost of one conversation add
# MEM0_QUEUE_WARMUP=true               # preload the Ollama model after idleness
# MEM0_QUEUE_GC_INTERVAL=3600
# MEM0_QUEUE_DONE_RETENTION=604800     # 7d; <=0 keeps done rows forever
# MEM0_QUEUE_DEAD_RETENTION=2592000    # 30d; dead rows are the inspect/requeue material

# --- Document ingestion (v0.5a — digital PDFs) ---
# MEM0_DOC_ENABLED=true                # kill switch for add_document
# MEM0_DOC_PATH_ALLOWLIST=             # ':'-separated path prefixes; default $HOME
# MEM0_DOC_SPOOL_DIR=                  # default ~/.mem0/ingest_spool
# MEM0_DOC_MAX_BYTES=26214400          # 25MB
# MEM0_DOC_MAX_PAGES=50                # rejects (never truncates) larger documents
# MEM0_DOC_CHUNK_CHARS=1800
# MEM0_DOC_CHUNK_OVERLAP=200
# MEM0_DOC_EXTRACT_TIMEOUT=120         # pdftotext timeout (seconds)
# MEM0_DOC_EST_CHUNK_S=35              # wait-estimate cost of one document chunk
# MEM0_DOC_INTERLEAVE=true             # conversations jump the line between chunks
# MEM0_DOC_INTERLEAVE_MAX=2            # max conversations drained per chunk

# --- Vision / image ingestion (v0.5b — scanned PDFs + images) ---
# MEM0_ENABLE_VISION=false             # true = OCR scanned pages + ingest PNG/JPEG via a local VLM
# MEM0_VLM_MODEL=qwen3-vl:4b-instruct  # local Ollama VLM (use an -instruct variant; thinking models return empty)
# MEM0_VLM_URL=                        # defaults to MEM0_LLM_URL / MEM0_OLLAMA_URL / localhost:11434
# MEM0_VLM_TIMEOUT=300                 # per-page transcription timeout (seconds)
# MEM0_VLM_DPI=150                     # pdftoppm rasterization DPI for scanned pages
# MEM0_VLM_NUM_PREDICT=2048            # max transcription tokens per page
# MEM0_VLM_NUM_CTX=8192                # context window; a 150-DPI page is ~4k vision tokens, default 4096 overflows
# MEM0_VLM_KEEP_ALIVE=5m               # keep the VLM resident during a document's transcription phase
